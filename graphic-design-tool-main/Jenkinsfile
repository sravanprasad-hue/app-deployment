pipeline {
    agent any

    stages {

        stage('Build Docker Containers') {
            steps {
                dir('graphic-design-tool-main') {
                    sh 'docker-compose down'
                    sh 'docker-compose up -d --build'
                }
            }
        }

        stage('Verify Running Containers') {
            steps {
                sh 'docker ps'
            }
        }

    }
}
